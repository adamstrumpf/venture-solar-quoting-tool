# Copy to .env.local for local development
# Set these as Cloud Run env vars for production

# Salesforce Connected App
SF_CLIENT_ID=
SF_CALLBACK_URL=

# Standalone initially
STANDALONE_INITIALLY_API_KEY=

# Google Maps / Places API key (powers Customer Address autocomplete).
# Set as a Cloud Run env var: gcloud run services update venture-solar-quoting-tool \
#   --region us-east1 --update-env-vars GOOGLE_MAPS_API_KEY=your_key_here
# Leave empty to disable autocomplete (the address field still works as plain text).
GOOGLE_MAPS_API_KEY=
